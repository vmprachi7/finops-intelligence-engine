# ── Copy this file to .env and fill in your values ──────────
# cp .env.example .env

# ── AI — Groq (completely free, no credit card) ───────────────
# Sign up at: https://console.groq.com
# Go to: API Keys → Create key
GROQ_API_KEY=gsk_your-groq-key-here

# ── Azure (leave blank to use mock data) ─────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── App behaviour ─────────────────────────────────────────────
USE_MOCK_DATA=true
LOOKBACK_DAYS=30
ANOMALY_THRESHOLD_PCT=30
DAILY_BUDGET_USD=10
MONTHLY_BUDGET_USD=100

MOCK_METRICS=true
